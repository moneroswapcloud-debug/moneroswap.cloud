---
---
<footer>
    <div class="footer-content">
        <div class="footer-logo">
            <img src="/logo_moneroswap_final.png" alt="Logo" class="logo-icon">
            <div>MoneroSwap.cloud</div>
            <a href="/canary.txt" target="_blank" class="canary-badge-small">Canary: ✅ Active</a>
        </div>
        <div class="footer-links">
            <a href="#terms" id="tos-link-footer">Terms of Service</a>
            <a href="#privacy" id="privacy-link-footer">Privacy Policy</a>
            <a href="/canary.txt" target="_blank">Warrant Canary</a>
            <a href="https://changenow.io/terms-of-use" target="_blank" rel="noopener">ChangeNOW Support</a>
        </div>
        <p class="footer-disclaimer">Powered by ChangeNOW.io liquidity infrastructure. We don't collect personal data. Privacy by default.</p>
    </div>
</footer>

<style>
    footer {
        padding: 3rem 0;
        border-top: 1px solid var(--glass-border);
    }

    .footer-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
    }

    .footer-logo {
        font-family: 'Outfit', sans-serif;
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--primary);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        text-align: center;
    }

    .logo-icon {
        width: 64px;
        height: 64px;
        object-fit: contain;
    }

    .footer-links {
        display: flex;
        gap: 2rem;
        flex-wrap: wrap;
        justify-content: center;
    }

    .footer-links a {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.875rem;
        transition: color 0.2s ease;
    }

    .footer-links a:hover {
        color: var(--primary);
    }

    .footer-disclaimer {
        font-size: 0.75rem;
        color: var(--text-muted);
        text-align: center;
        max-width: 400px;
    }

    .canary-badge-small {
        font-size: 0.65rem;
        color: var(--success);
        text-decoration: none;
        padding: 0.2rem 0.5rem;
        background: rgba(0, 255, 136, 0.05);
        border: 1px solid rgba(0, 255, 136, 0.2);
        border-radius: 4px;
        margin-top: 0.25rem;
        transition: all 0.2s ease;
    }

    .canary-badge-small:hover {
        background: rgba(0, 255, 136, 0.1);
        border-color: var(--success);
    }
</style>

---
---
<footer>
    <div class="footer-content">
        <div class="footer-logo">
            <img src="/logo_moneroswap_final.png" alt="Logo" class="logo-icon">
            <div>MoneroSwap.cloud</div>
            <a href="/canary.txt" target="_blank" class="canary-badge-small">Canary: ✅ Active</a>
        </div>
        <div class="footer-links">
            <a href="/terms" id="tos-link-footer">Terms of Service</a>
            <a href="#privacy" id="privacy-link-footer">Privacy Policy</a>
            <a href="/canary.txt" target="_blank">Warrant Canary</a>
            <a href="https://matrix.to/#/#moneroswap.cloud:matrix.org" target="_blank" style="display: inline-flex; align-items: center; gap: 0.5rem;">
                <svg viewBox="0 0 24 24" fill="currentColor" style="width: 14px; height: 14px;">
                    <path d="M.632.402h1.49v2.106C3.55.933 5.903 0 8.01 0c2.193 0 3.841.895 4.84 2.193C13.85.895 15.498 0 17.69 0c2.107 0 4.46.933 5.888 2.508V.402h1.49v23.196h-1.49V21.49c-1.428 1.575-3.781 2.508-5.888 2.508-2.193 0-3.841-.894-4.84-2.192-1.002 1.298-2.65 2.192-4.84 2.192-2.107 0-4.46-.933-5.888-2.508V23.598h-1.49V.402zM16.5 4.6c-2.3 0-3.8 1.4-3.8 3.8v7.2c0 2.4 1.5 3.8 3.8 3.8s3.8-1.4 3.8-3.8v-7.2c0-2.4-1.5-3.8-3.8-3.8zM7.5 4.6c-2.3 0-3.8 1.4-3.8 3.8v7.2c0 2.4 1.5 3.8 3.8 3.8s3.8-1.4 3.8-3.8v-7.2c0-2.4-1.5-3.8-3.8-3.8z"/>
                </svg>
                Anonymous Support (Matrix)
            </a>
        </div>
        <p class="footer-business-contact">For business inquiries only: monerosw@protonmail.com</p>
        <p class="footer-disclaimer">Powered by ChangeNOW.io liquidity infrastructure. We don't collect personal data. Privacy by default.</p>
    </div>
</footer>

<style>
    footer {
        padding: 3rem 0;
        border-top: 1px solid var(--glass-border);
    }

    .footer-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
    }

    .footer-logo {
        font-family: 'Outfit', sans-serif;
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--primary);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        text-align: center;
    }

    .logo-icon {
        width: 64px;
        height: 64px;
        object-fit: contain;
    }

    .footer-links {
        display: flex;
        gap: 2rem;
        flex-wrap: wrap;
        justify-content: center;
    }

    .footer-links a {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.875rem;
        transition: color 0.2s ease;
    }

    .footer-links a:hover {
        color: var(--primary);
    }

    .footer-disclaimer {
        font-size: 0.75rem;
        color: var(--text-muted);
        text-align: center;
        max-width: 400px;
    }

    .footer-business-contact {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin: -0.5rem 0 1rem;
        text-align: center;
    }

    .canary-badge-small {
        font-size: 0.65rem;
        color: var(--success);
        text-decoration: none;
        padding: 0.2rem 0.5rem;
        background: rgba(0, 255, 136, 0.05);
        border: 1px solid rgba(0, 255, 136, 0.2);
        border-radius: 4px;
        margin-top: 0.25rem;
        transition: all 0.2s ease;
    }

    .canary-badge-small:hover {
        background: rgba(0, 255, 136, 0.1);
        border-color: var(--success);
    }
</style>

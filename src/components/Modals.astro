---
---
<!-- Modals -->

<div id="privacy-modal" class="modal-overlay">
    <div class="modal-content">
        <button class="modal-close">&times;</button>
        <div class="modal-header">
            <h3 class="modal-title">Privacy Policy</h3>
        </div>
        <div class="modal-body">
            <p>At MoneroSwap, your privacy is our highest priority. We have designed our platform to collect the minimum amount of data necessary.</p>
            
            <h4>1. No Personal Data</h4>
            <p>Since we do not collect personal data, we have nothing to sell or share with third parties, advertisers, or government agencies.</p>

            <h4>2. Zero Logs Policy</h4>
            <p>Our backend proxy is configured to <strong>never log IP addresses</strong>, user agents, or metadata associated with your swap requests. Your connection remains private.</p>

            <h4>3. No Cookies</h4>
            <p>MoneroSwap uses <strong>zero cookies</strong> and zero local tracking mechanisms. We do not use Google Analytics or any third-party tracking scripts.</p>

            <h4>4. Localized Assets</h4>
            <p>All assets (fonts, icons, scripts) are served directly from our infrastructure to prevent IP leaks to third-party CDNs or font providers.</p>
        </div>
    </div>
</div>

<div id="faq-modal" class="modal-overlay">
    <div class="modal-content">
        <button class="modal-close">&times;</button>
        <div class="modal-header">
            <h3 class="modal-title">Frequently Asked Questions</h3>
        </div>
        <div class="modal-body">
            <h4>What is MoneroSwap?</h4>
            <p>MoneroSwap is a non-custodial, privacy-focused cryptocurrency exchange designed to be a "Privacy Shield" for your transactions.</p>
            
            <h4>Is it really anonymous?</h4>
            <p>Yes. We use a private Node.js proxy that strips your IP address and metadata before communicating with liquidity providers. Combined with our No-Logs policy, your identity is fully protected.</p>

            <h4>What is the "Level 0" Guarantee?</h4>
            <p>It is our commitment that we will never, under any circumstances, stop a transaction to request identity documents (KYC). We believe financial privacy is a fundamental human right.</p>

            <h4>Do you use cookies?</h4>
            <p>No. We use zero cookies and zero trackers. Every time you visit the site, you are a completely new user to us.</p>
            
            <h4>How long does a swap take?</h4>
            <p>Most transactions are completed within 10-30 minutes, depending on the network speed of the assets being swapped.</p>
        </div>
    </div>
</div>

<div id="donation-modal" class="modal-overlay">
    <div class="modal-content" style="text-align: center;">
        <button class="modal-close">&times;</button>
        <div class="modal-header">
            <h3 class="modal-title">Support MoneroSwap</h3>
        </div>
        <div class="modal-body">
            <p>MoneroSwap is an independent project dedicated to financial privacy. Your donations help us maintain infrastructure.</p>
            
            <h4 style="color: #ff3366;">Donate Monero (XMR)</h4>
            <div style="background: rgba(255,255,255,0.05); padding: 1.5rem; border-radius: 1rem; border: 1px solid var(--glass-border); margin: 1.5rem 0; word-break: break-all;">
                <p id="xmr-address" style="font-family: monospace; font-size: 0.85rem; color: var(--text);">46oPebFDXZ3SB61Ufd1JXmKaaPvtHh7KHMpW9y3Nvhd2dHG88tPuhRmRGd8ArdnYmL5amD1eny8AK8Fkqmxu6kfHKKYwhA3</p>
                <button class="submit-btn" id="copy-xmr-btn" style="padding: 0.5rem 1rem; font-size: 0.8rem; margin-top: 1rem; width: auto; min-width: 150px;">Copy Address</button>
            </div>
            <p style="font-size: 0.8rem; color: var(--text-muted);">Thank you for supporting the privacy revolution!</p>
        </div>
    </div>
</div>

<script>
    const modals = {
        privacy: document.getElementById('privacy-modal'),
        faq: document.getElementById('faq-modal'),
        donation: document.getElementById('donation-modal')
    };

    const links = {
        privacy: document.getElementById('privacy-link'),
        faq: document.getElementById('faq-link'),
        donation: document.getElementById('donation-link')
    };

    function openModal(m) { if(m) m.style.display = 'flex'; }
    function closeModal(m) { if(m) m.style.display = 'none'; }

    Object.keys(links).forEach(key => {
        links[key]?.addEventListener('click', (e) => {
            e.preventDefault();
            openModal(modals[key]);
        });
    });

    document.querySelectorAll('.modal-close').forEach(btn => {
        btn.addEventListener('click', () => {
            Object.values(modals).forEach(closeModal);
        });
    });

    window.addEventListener('click', (e) => {
        Object.values(modals).forEach(m => {
            if (e.target === m) closeModal(m);
        });
    });

    document.getElementById('copy-xmr-btn')?.addEventListener('click', () => {
        const addr = document.getElementById('xmr-address')?.textContent;
        if (addr) {
            navigator.clipboard.writeText(addr);
            const btn = document.getElementById('copy-xmr-btn');
            if (btn) {
                btn.textContent = 'Copied!';
                setTimeout(() => btn.textContent = 'Copy Address', 2000);
            }
        }
    });

    // Hash handling
    const checkHash = () => {
        if (window.location.hash === '#privacy') openModal(modals.privacy);
        if (window.location.hash === '#faq') openModal(modals.faq);
        if (window.location.hash === '#donate') openModal(modals.donation);
    };
    window.addEventListener('hashchange', checkHash);
    checkHash();
</script>

---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import SwapWidget from '../components/SwapWidget.astro';
import Modals from '../components/Modals.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
	title="MoneroSwap — Anonymous No-KYC Crypto Exchange | Onion-ready"
	description="Swap Bitcoin, Ethereum and more to Monero instantly. 100% No-KYC, no logs, and fully Onion-ready for maximum network anonymity. Your privacy is absolute."
>
	<Header />
	<main>
		<Hero />
		<SwapWidget />
	</main>
	<Footer />
	<Modals />
</Layout>

<style>
	main {
		min-height: 80vh;
	}
</style>
